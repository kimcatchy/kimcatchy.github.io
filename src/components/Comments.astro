<section class="w-full">
  <div id="utterances-container" class="w-full"></div>

  <style is:global>
    /* utterances가 생성하는 iframe의 기본 max-width(760px) 제한 해제 */
    .utterances {
      max-width: 100% !important;
    }
  </style>

  <script is:inline>
    function loadUtterances() {
      const script = document.createElement('script');
      script.src = 'https://utteranc.es/client.js';
      script.setAttribute('repo', 'kimcatchy/utterances');
      script.setAttribute('issue-term', 'title');
      script.setAttribute('theme', 'github-dark');
      script.setAttribute('crossorigin', 'anonymous');
      script.async = true;

      const container = document.getElementById('utterances-container');
      if (container) {
        container.innerHTML = '';
        container.appendChild(script);
      }
    }

    // Initial load
    loadUtterances();

    // Re-load on Astro page transitions
    document.addEventListener('astro:after-swap', loadUtterances);
  </script>
</section>
