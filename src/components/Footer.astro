---

<footer class="w-full border-t border-border/40 bg-secondary/15 backdrop-blur-md mt-auto">
	<div class="mx-auto flex h-14 max-w-[1400px] items-center justify-between px-4 sm:px-6 md:px-10">
		<p class="text-xs text-muted-foreground/60 tracking-tight uppercase font-medium">
			&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
		</p>
		
		<div class="flex items-center gap-4">
			{socialItems.map(item => (
				<a href={item.href} target="_blank" class="text-muted-foreground/40 hover:text-primary transition-colors focus:outline-none" title={item.label}>
					<span class="sr-only">{item.label}</span>
					<svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" set:html={item.svg} />
				</a>
			))}
		</div>
	</div>
</footer>
