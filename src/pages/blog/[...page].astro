---
import TwoColumnLayout from '../../layouts/TwoColumnLayout.astro';
import { getCollection } from 'astro:content';
import { Breadcrumb, BreadcrumbItem, BreadcrumbLink, BreadcrumbList, BreadcrumbPage, BreadcrumbSeparator } from '@/components/ui/breadcrumb';
import PostList from '../../components/post/PostList.astro';
import Pagination from '../../components/post/Pagination.astro';

export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;
const posts = page.data;
---

<TwoColumnLayout title="Blog Archive">
	<!-- Breadcrumbs -->
	<Breadcrumb className="mb-6">
		<BreadcrumbList className="text-xs font-black uppercase text-muted-foreground/60 tracking-tight">
			<BreadcrumbItem>
				<BreadcrumbLink href={import.meta.env.BASE_URL} className="hover:text-primary transition-colors">Home</BreadcrumbLink>
			</BreadcrumbItem>
			<BreadcrumbSeparator className="opacity-30" />
			<BreadcrumbItem>
				<BreadcrumbPage className="text-foreground/40">Archive {page.currentPage > 1 && `(Page ${page.currentPage})`}</BreadcrumbPage>
			</BreadcrumbItem>
		</BreadcrumbList>
	</Breadcrumb>

	<PostList posts={posts} />

  <Pagination page={page} baseUrl={`${import.meta.env.BASE_URL}blog/`} />
</TwoColumnLayout>
